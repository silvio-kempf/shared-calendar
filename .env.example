# Diesen Wert mit einem zufälligen langen String ersetzen!
SECRET_KEY=change-this-to-a-long-random-string

# Port, auf dem der Kalender erreichbar ist (Standard: 80)
PORT=80

# E-Mail-Benachrichtigungen (optional – leer lassen um Benachrichtigungen zu deaktivieren)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
